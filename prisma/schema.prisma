datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  STARTER
  BUSINESS
}

enum Role {
  USER
  ASSISTANT
  SYSTEM
}

enum OrderStatus {
  NEW
  CONFIRMED
  PREPARING
  DELIVERED
  CANCELLED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  FAILED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  telegramId      BigInt?   @unique
  phone           String?   @unique
  name            String
  email           String?   @unique
  emailVerified   DateTime?
  hashedPassword  String?
  image           String?
  language        String    @default("ru")
  plan            Plan      @default(FREE)
  planExpiresAt   DateTime?
  isVerified      Boolean   @default(false)
  lastLoginAt     DateTime?
  bots            Bot[]
  accounts        Account[]
  sessions        AuthSession[]
  wizardSession   WizardSession?
  subscriptions   Subscription[]
  payments        Payment[]
  notifications   Notification[]
  createdAt       DateTime  @default(now())
}

// ─── NextAuth Models ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WizardSession {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps     Json     @default("{}")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Bot {
  id               String          @id @default(cuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id])
  name             String
  description      String          @db.Text
  businessType     String
  botLanguages     String[]
  personality      String          @default("friendly")
  welcomeMessage   String          @db.Text
  workingHours     Json?
  address          String?
  managerContact   String?
  telegramToken    String?         @unique
  telegramBotName  String?
  instagramPageId  String?
  whatsappPhoneId  String?
  isActive         Boolean         @default(false)
  scenario         Json?
  capabilities     String[]
  // AI Engine settings (per-bot)
  aiModel          String          @default("gpt-4o-mini")
  aiTemperature    Float           @default(0.7)
  aiMaxTokens      Int             @default(1024)
  aiMaxContext      Int             @default(10)
  confidenceThreshold Float        @default(0.6)
  products         Product[]
  services         Service[]
  knowledgeDocs    KnowledgeDoc[]
  faqItems         FAQItem[]
  conversations    Conversation[]
  orders           Order[]
  bookings         Booking[]
  broadcasts       Broadcast[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([userId])
}

model Product {
  id          String   @id @default(cuid())
  botId       String
  bot         Bot      @relation(fields: [botId], references: [id])
  name        String
  nameUz      String?
  description String?  @db.Text
  price       Decimal
  currency    String   @default("UZS")
  category    String?
  imageUrl    String?
  inStock     Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([botId])
}

model Service {
  id          String   @id @default(cuid())
  botId       String
  bot         Bot      @relation(fields: [botId], references: [id])
  name        String
  nameUz      String?
  description String?  @db.Text
  price       Decimal
  currency    String   @default("UZS")
  durationMin Int?
  createdAt   DateTime @default(now())

  @@index([botId])
}

model FAQItem {
  id         String   @id @default(cuid())
  botId      String
  bot        Bot      @relation(fields: [botId], references: [id])
  question   String
  questionUz String?
  answer     String   @db.Text
  answerUz   String?  @db.Text
  isAutoGen  Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([botId])
}

model KnowledgeDoc {
  id        String           @id @default(cuid())
  botId     String
  bot       Bot              @relation(fields: [botId], references: [id])
  title     String
  source    String
  content   String           @db.Text
  chunks    KnowledgeChunk[]
  createdAt DateTime         @default(now())

  @@index([botId])
}

model KnowledgeChunk {
  id         String       @id @default(cuid())
  docId      String
  doc        KnowledgeDoc @relation(fields: [docId], references: [id])
  content    String       @db.Text
  embedding  Float[]
  tokenCount Int
}

model Conversation {
  id             String    @id @default(cuid())
  botId          String
  bot            Bot       @relation(fields: [botId], references: [id])
  platform       String
  platformChatId String
  customerName   String?
  customerPhone  String?
  language       String?
  state          Json      @default("{}")
  messages       Message[]
  orders         Order[]
  isResolved     Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([botId, platform])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  role           Role
  content        String       @db.Text
  platform       String
  confidence     Float?
  handedOff      Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

model Order {
  id              String       @id @default(cuid())
  botId           String
  bot             Bot          @relation(fields: [botId], references: [id])
  conversationId  String?
  conversation    Conversation? @relation(fields: [conversationId], references: [id])
  items           Json
  total           Decimal
  currency        String       @default("UZS")
  status          OrderStatus  @default(NEW)
  customerName    String?
  customerPhone   String
  deliveryAddress String?
  notes           String?
  createdAt       DateTime     @default(now())

  @@index([botId])
}

model Booking {
  id            String        @id @default(cuid())
  botId         String
  bot           Bot           @relation(fields: [botId], references: [id])
  serviceId     String?
  customerName  String
  customerPhone String
  dateTime      DateTime
  status        BookingStatus @default(PENDING)
  notes         String?
  createdAt     DateTime      @default(now())

  @@index([botId])
}

model AILog {
  id              String   @id @default(cuid())
  botId           String
  conversationId  String?
  userMessage     String   @db.Text
  systemPrompt    String   @db.Text
  aiResponse      String   @db.Text
  model           String
  tokensUsed      Int      @default(0)
  confidence      Float    @default(0)
  intent          String   @default("unknown")
  latencyMs       Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([botId, createdAt])
}

// ─── Payments & Subscriptions ───────────────────────────────────────────────

model Subscription {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  plan          Plan
  startDate     DateTime
  endDate       DateTime
  isActive      Boolean   @default(true)
  autoRenew     Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@index([userId])
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  provider        String
  externalId      String?
  amount          Decimal
  currency        String        @default("UZS")
  status          PaymentStatus @default(PENDING)
  description     String?
  createdAt       DateTime      @default(now())

  @@index([userId])
}

// ─── Notifications ──────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  body      String   @db.Text
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

// ─── Broadcasts ─────────────────────────────────────────────────────────────

model Broadcast {
  id          String          @id @default(cuid())
  botId       String
  bot         Bot             @relation(fields: [botId], references: [id])
  message     String          @db.Text
  imageUrl    String?
  filters     Json?
  status      BroadcastStatus @default(DRAFT)
  totalSent   Int             @default(0)
  totalFailed Int             @default(0)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime        @default(now())

  @@index([botId])
}
